{
  "basePath": "/",
  "url": "https://grahammacaree.com",
  "name": "Graham MacAree",
  "email": "hi@grahammacaree.com",
  "description": "This is the personal site of Graham MacAree — engineer, editor and analyst",
  "person": {
    "jobTitle": "Editorial/Engineering Leader"
  },
  "pdfExports": [
    {
      "id": "1BwkOgdqOQAKj22LmRZDDgb2MZsRM7DGXnffhreBQReY",
      "path": "cv.pdf"
    }
  ],
  "home": {
    "output": "index.html",
    "pageType": "home",
    "sections": ["intro", "thesis", "reading"]
  },
  "chrome": {
    "components": {
      "topBar": "site-top-bar",
      "footer": "site-footer"
    },
    "docRefs": {
      "cv": "cv",
      "about": "about",
      "studies": "studies"
    },
    "assets": {
      "backChevron": "chevrons/left.svg"
    },
    "scripts": ["jovian.js"]
  },
  "docTypes": {
    "intro": {
      "section": "intro",
      "contentPath": "{slug}.html",
      "publish": false
    },
    "thesis": {
      "section": "document",
      "sectionId": "thesis",
      "contentPath": "{slug}.html",
      "publish": false,
      "endmark": true
    },
    "story": {
      "section": "document",
      "contentPath": "stories/{slug}.html",
      "publishPath": "stories/{slug}.html",
      "publish": true,
      "pageType": "default",
      "endmark": true
    },
    "cv": {
      "section": "document",
      "contentPath": "{slug}.html",
      "publishPath": "{slug}.html",
      "publish": true,
      "pageType": "cv",
      "endmark": "before-hr"
    },
    "about": {
      "section": "document",
      "contentPath": "{slug}.html",
      "publishPath": "{slug}.html",
      "publish": true,
      "pageType": "about"
    },
    "reading": {
      "section": "reading",
      "contentPath": "{slug}.html",
      "publish": false,
      "parse": "reading"
    },
    "studies": {
      "section": "studies",
      "contentPath": "{slug}.html",
      "publishPath": "{slug}.html",
      "publish": true,
      "pageType": "studies",
      "parse": "studies"
    }
  },
  "pageTypes": {
    "home": {
      "layout": "page",
      "title": "siteName",
      "bodyClass": "body--home",
      "leftNav": "brand",
      "cvNav": "link",
      "studiesNav": "link",
      "scripts": ["life.js"]
    },
    "default": {
      "layout": "page",
      "title": "docTitle",
      "leftNav": "back",
      "cvNav": "link",
      "studiesNav": "link",
      "aboutLink": true,
      "scripts": ["life.js"]
    },
    "cv": {
      "extends": "default",
      "cvNav": "current",
      "studiesNav": "link",
      "aboutLink": true
    },
    "about": {
      "extends": "default",
      "aboutLink": false,
      "scripts": []
    },
    "studies": {
      "extends": "default",
      "bodyClass": "body--studies",
      "cvNav": "link",
      "studiesNav": "current",
      "aboutLink": true,
      "scripts": ["studies.js"]
    }
  }
}
